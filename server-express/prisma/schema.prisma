datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Passagem {
  id          Int    @id @default(autoincrement())
  origem      String
  destino     String
  preco       Float
  desconto    Int
  imagem      String
  dataPartida String
  companhia   String
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  criadoEm DateTime @default(now())
}

model Banner {
  id             Int      @id @default(autoincrement())
  titulo         String
  descricao      String
  imagem         String
  linkDestino    String
  ativo          Boolean  @default(true)
  tipo           String   // "hero" ou "carousel"
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
}

model Hotel {
  id             Int      @id @default(autoincrement())
  nome           String
  descricao      String
  preco          Float
  estrelas       Int
  imagem         String
  localizacao    String
  destaque       Boolean  @default(false)
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt
}